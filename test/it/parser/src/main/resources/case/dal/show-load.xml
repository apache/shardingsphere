<sql-parser-test-cases>
    <doris-show-load sql-case-id="doris_show_load_simple" />

    <doris-show-load sql-case-id="doris_show_load_with_database">
        <database name="example_db" start-index="15" stop-index="24" />
    </doris-show-load>

    <doris-show-load sql-case-id="doris_show_load_with_where_like_and_limit">
        <database name="example_db" start-index="15" stop-index="24" />
        <where start-index="26" stop-index="54">
            <expr>
                <binary-operation-expression start-index="32" stop-index="54">
                    <left>
                        <column name="LABEL" start-index="32" stop-index="36" />
                    </left>
                    <operator>LIKE</operator>
                    <right>
                        <list-expression start-index="43" stop-index="54">
                            <items>
                                <literal-expression value="2014_01_02" start-index="43" stop-index="54" />
                            </items>
                        </list-expression>
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
        <limit start-index="62" stop-index="63">
            <row-count value="10" start-index="62" stop-index="63" />
        </limit>
    </doris-show-load>

    <doris-show-load sql-case-id="doris_show_load_with_where_eq_and_order_by">
        <database name="example_db" start-index="15" stop-index="24" />
        <where start-index="26" stop-index="65">
            <expr>
                <binary-operation-expression start-index="32" stop-index="65">
                    <left>
                        <column name="LABEL" start-index="32" stop-index="36" />
                    </left>
                    <operator>=</operator>
                    <right>
                        <literal-expression value="load_example_db_20140102" start-delimiter="'" end-delimiter="'" start-index="40" stop-index="65" />
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
        <order-by>
            <column-item name="LoadStartTime" start-index="76" stop-index="88" order-direction="DESC" />
        </order-by>
    </doris-show-load>

    <doris-show-load sql-case-id="doris_show_load_with_where_and_order_by">
        <database name="example_db" start-index="15" stop-index="24" />
        <where start-index="26" stop-index="87">
            <expr>
                <binary-operation-expression start-index="32" stop-index="87">
                    <left>
                        <binary-operation-expression start-index="32" stop-index="65">
                            <left>
                                <column name="LABEL" start-index="32" stop-index="36" />
                            </left>
                            <operator>=</operator>
                            <right>
                                <literal-expression value="load_example_db_20140102" start-delimiter="'" end-delimiter="'" start-index="40" stop-index="65" />
                            </right>
                        </binary-operation-expression>
                    </left>
                    <operator>AND</operator>
                    <right>
                        <binary-operation-expression start-index="71" stop-index="87">
                            <left>
                                <column name="STATE" start-index="71" stop-index="75" />
                            </left>
                            <operator>=</operator>
                            <right>
                                <literal-expression value="loading" start-delimiter="'" end-delimiter="'" start-index="79" stop-index="87" />
                            </right>
                        </binary-operation-expression>
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
        <order-by>
            <column-item name="LoadStartTime" start-index="98" stop-index="110" order-direction="DESC" />
        </order-by>
    </doris-show-load>

    <doris-show-load sql-case-id="doris_show_load_with_limit_offset">
        <database name="example_db" start-index="15" stop-index="24" />
        <order-by>
            <column-item name="LoadStartTime" start-index="35" stop-index="47" order-direction="DESC" />
        </order-by>
        <limit start-index="60" stop-index="72">
            <row-count value="10" start-index="60" stop-index="61" />
            <offset value="5" start-index="70" stop-index="70" />
        </limit>
    </doris-show-load>
</sql-parser-test-cases>
