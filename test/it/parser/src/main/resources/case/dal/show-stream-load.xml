<sql-parser-test-cases>
    <doris-show-stream-load sql-case-id="doris_show_stream_load_simple" />

    <doris-show-stream-load sql-case-id="doris_show_stream_load_with_database">
        <database name="example_db" start-index="22" stop-index="31" />
    </doris-show-stream-load>

    <doris-show-stream-load sql-case-id="doris_show_stream_load_with_where_like_and_limit">
        <database name="example_db" start-index="22" stop-index="31" />
        <where start-index="33" stop-index="61">
            <expr>
                <binary-operation-expression start-index="39" stop-index="61">
                    <left>
                        <column name="LABEL" start-index="39" stop-index="43" />
                    </left>
                    <operator>LIKE</operator>
                    <right>
                        <list-expression start-index="50" stop-index="61">
                            <items>
                                <literal-expression value="2014_01_02" start-index="50" stop-index="61" />
                            </items>
                        </list-expression>
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
        <limit start-index="69" stop-index="70">
            <row-count value="10" start-index="69" stop-index="70" />
        </limit>
    </doris-show-stream-load>

    <doris-show-stream-load sql-case-id="doris_show_stream_load_with_where_eq">
        <database name="example_db" start-index="22" stop-index="31" />
        <where start-index="33" stop-index="72">
            <expr>
                <binary-operation-expression start-index="39" stop-index="72">
                    <left>
                        <column name="LABEL" start-index="39" stop-index="43" />
                    </left>
                    <operator>=</operator>
                    <right>
                        <literal-expression value="load_example_db_20140102" start-delimiter="'" end-delimiter="'" start-index="47" stop-index="72" />
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
    </doris-show-stream-load>

    <doris-show-stream-load sql-case-id="doris_show_stream_load_with_where_status_and_order_by">
        <database name="example_db" start-index="22" stop-index="31" />
        <where start-index="33" stop-index="56">
            <expr>
                <binary-operation-expression start-index="39" stop-index="56">
                    <left>
                        <column name="STATUS" start-index="39" stop-index="44" />
                    </left>
                    <operator>=</operator>
                    <right>
                        <literal-expression value="success" start-delimiter="'" end-delimiter="'" start-index="48" stop-index="56" />
                    </right>
                </binary-operation-expression>
            </expr>
        </where>
        <order-by>
            <column-item name="StartTime" start-index="67" stop-index="75" order-direction="DESC" />
        </order-by>
    </doris-show-stream-load>

    <doris-show-stream-load sql-case-id="doris_show_stream_load_with_limit_offset">
        <database name="example_db" start-index="22" stop-index="31" />
        <order-by>
            <column-item name="StartTime" start-index="42" stop-index="50" order-direction="DESC" />
        </order-by>
        <limit start-index="63" stop-index="73">
            <row-count value="10" start-index="63" stop-index="64" />
            <offset value="5" start-index="73" stop-index="73" />
        </limit>
    </doris-show-stream-load>
</sql-parser-test-cases>
