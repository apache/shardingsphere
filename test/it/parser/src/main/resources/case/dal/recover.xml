<sql-parser-test-cases>
    <recover sql-case-id = "recover_database_by_name">
        <database name = "example_db" start-index = "17" stop-index = "26" />
    </recover>
    <recover sql-case-id="recover_table_by_name">
        <database name = "example_db" start-index="14" stop-index="23">
            <table name = "example_tbl" start-index = "14" stop-index = "35"/>
        </database>
    </recover>
    <recover sql-case-id="recover_partition_by_name">
        <partition name = "p1" start-index = "18" stop-index="19"/>
        <table name="example_tbl" start-index="21" stop-index="36"/>
    </recover>
    <recover sql-case-id="recover_database_by_name_and_id">
        <database name = "example_db" start-index="14" stop-index="23"/>
        <databaseid name = "example_db_id" start-index="37" stop-index="50"/>
    </recover>
    <recover sql-case-id="recover_table_by_name_and_id">
        <database name = "example_db" start-index="14" stop-index="23">
            <table name = "example_tbl" start-index="14" stop-index="35"/>
        </database>
        <tableid name = "example_tbl_id" start-index="37" stop-index="50"/>
    </recover>
    <recover sql-case-id="recover_partition_by_name_and_id">
        <partition name="p1" start-index="18" stop-index="19"/>
        <partitionid name = "p1_id" start-index="21" stop-index="25"/>
        <table name="example_tbl" start-index="27" stop-index="42"/>
    </recover>
    <recover sql-case-id="recover_database_by_name_as">
        <database name="example_db" start-index="17" stop-index="26"/>
        <databaseid name="example_db_id" start-index="28" stop-index="40"/>
        <newdatabase name="new_example_db" start-index="42" stop-index="58"/>
    </recover>
    <recover sql-case-id="recover_table_by_name_and_id_as">
        <database name="example_db" start-index="14" stop-index="23">
            <table name="example_tbl" start-index="14" stop-index="35"/>
        </database>
        <newtable name="new_example_tbl" start-index="37" stop-index="54"/>
    </recover>
</sql-parser-test-cases>
